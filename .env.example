# ─── TuniTech Abroad — Environment Variables Example ────────────────────────
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# Do not put real secrets here.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# Django environment selector
DJANGO_ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local

# Django security
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-domain.example
SITE_URL=https://your-domain.example
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Logging
DJANGO_LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=tunitech_abroad
POSTGRES_USER=tunitech
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed database URL (alternative to individual vars above)
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# ─── CV uploads ───────────────────────────────────────────────────────────────
MAX_CV_UPLOAD_SIZE_MB=5

# ─── Future phases — leave blank in Phase 0 ──────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ─── LLM Integration ──────────────────────────────────────────────────────────
LLM_ENABLED=False
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-pro

# ─── Job Enrichment Pipeline ──────────────────────────────────────────────────
JOB_ENRICHMENT_ENABLED=False
JOB_RECOMMENDATIONS_USE_ENRICHED_DATA=False
JOB_ENRICHMENT_MODEL=
JOB_ENRICHMENT_DAILY_LIMIT=1000
JOB_ENRICHMENT_MAX_CHARS=6000
JOB_ENRICHMENT_MAX_RETRIES=2
