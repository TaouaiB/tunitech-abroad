# ─── TuniTech Abroad — Environment Variables Example ────────────────────────
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# Do not put real secrets here.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# Django environment selector
DJANGO_ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local

# Django security
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Logging
DJANGO_LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=tunitech_abroad
POSTGRES_USER=tunitech
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed database URL (alternative to individual vars above)
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# ─── CV uploads ───────────────────────────────────────────────────────────────
MAX_CV_UPLOAD_SIZE_MB=5

# ─── Future phases — leave blank in Phase 0 ──────────────────────────────────
OPENROUTER_API_KEY=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
