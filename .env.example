# ─── TuniAtlas — Environment Variables Example ────────────────────────────────
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# Do not put real secrets here.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# Django environment selector
DJANGO_ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local

# Django security
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ADMIN_URL=admin/
CSRF_TRUSTED_ORIGINS=https://your-domain.example
SITE_URL=https://your-domain.example
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Logging
DJANGO_LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=tunitech_abroad
POSTGRES_USER=tunitech
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed database URL (alternative to individual vars above)
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Celery ───────────────────────────────────────────────────────────────────
# Keep normal tasks and OpenRouter enrichment on separate workers locally:
# celery -A config worker -l info -Q celery -c 2
# celery -A config worker -l info -Q llm -c 1 --prefetch-multiplier=1
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# ─── CV uploads ───────────────────────────────────────────────────────────────
MAX_CV_UPLOAD_SIZE_MB=5

# ─── Email Integration ──────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=contact@tuniatlas.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL="TuniAtlas <contact@tuniatlas.com>"
SERVER_EMAIL=contact@tuniatlas.com

# ─── LLM Integration ──────────────────────────────────────────────────────────
LLM_ENABLED=True
CV_LLM_EXTRACTION_ENABLED=False
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-pro

# ─── Job Enrichment Pipeline ──────────────────────────────────────────────────
# IMPORTANT: Enrichment consumes OpenRouter credits. Disabled by default.
JOB_ENRICHMENT_ENABLED=False
JOB_RECOMMENDATIONS_USE_ENRICHED_DATA=False
JOB_ENRICHMENT_MODEL=
JOB_ENRICHMENT_DAILY_LIMIT=0
JOB_ENRICHMENT_MAX_PER_INGESTION_RUN=0
JOB_ENRICHMENT_MIN_RELEVANCE=partial
JOB_ENRICHMENT_MAX_CHARS=6000
JOB_ENRICHMENT_MAX_RETRIES=2
JOB_ENRICHMENT_RETRY_ENABLED=False
JOB_ENRICHMENT_RETRY_MAX_PER_RUN=10
JOB_ENRICHMENT_RETRY_COOLDOWN_MINUTES=60
JOB_ENRICHMENT_PROCESSING_STALE_MINUTES=60
OPENROUTER_ENRICHMENT_RATE_LIMIT=1/m
OPENROUTER_ENRICHMENT_QUEUE=llm
OPENROUTER_CIRCUIT_BREAKER_ENABLED=True
OPENROUTER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
OPENROUTER_CIRCUIT_BREAKER_WINDOW_MINUTES=30
OPENROUTER_CIRCUIT_BREAKER_COOLDOWN_MINUTES=60
# Disabled by default. Enables a hard-capped canary retry for provider_blocked enrichments.
JOB_ENRICHMENT_FORCE_PROVIDER_BLOCKED_RETRY=False

# ─── France Travail Provider Safety ──────────────────────────────────────────
# These defaults are intentionally conservative. Public job search reads local DB only.
FRANCE_TRAVAIL_REQUEST_DELAY_SECONDS=0.5
FRANCE_TRAVAIL_MAX_REQUESTS_PER_RUN=100
FRANCE_TRAVAIL_BACKOFF_ON_429_SECONDS=60

CELERY_HEARTBEAT_STALE_MINUTES=15
CV_PARSE_STALE_MINUTES=15
INGESTION_STALE_RUNNING_MINUTES=60
